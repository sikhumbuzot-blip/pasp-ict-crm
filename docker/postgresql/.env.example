# PostgreSQL Docker Environment Configuration
# Copy this file to .env and update the values for your environment

# Database Configuration
DB_PASSWORD=your_secure_database_password_here

# Application Configuration
ENCRYPTION_KEY=your_32_character_encryption_key_here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password_here

# PgAdmin Configuration
PGADMIN_EMAIL=admin@yourcompany.com
PGADMIN_PASSWORD=your_pgadmin_password_here

# Backup Configuration
BACKUP_RETENTION_DAYS=30
BACKUP_ENABLED=true

# Email Configuration (Optional)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_email_password

# Notification Configuration (Optional)
NOTIFICATION_ENABLED=true
NOTIFICATION_FROM_EMAIL=noreply@yourcompany.com
NOTIFICATION_SYSTEM_NAME=Sales CRM System
NOTIFICATION_ADMIN_EMAILS=admin@yourcompany.com