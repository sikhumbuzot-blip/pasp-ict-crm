# Sales CRM Application Environment Configuration
# Copy this file to .env and update the values as needed

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crmdb_dev
DB_USERNAME=crmuser
DB_PASSWORD=crmpass

# Application Security
ENCRYPTION_KEY=defaultEncryptionKey123456789012
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Email Configuration (Optional)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# Backup Configuration
BACKUP_DIRECTORY=backups
BACKUP_RETENTION_DAYS=30
BACKUP_ENABLED=true

# Notification Configuration
NOTIFICATION_ENABLED=true
NOTIFICATION_FROM_EMAIL=noreply@salescrm.com
NOTIFICATION_SYSTEM_NAME=Sales CRM System
NOTIFICATION_ADMIN_EMAILS=admin@example.com

# Development Settings
SPRING_PROFILES_ACTIVE=dev